# Web build only (Tauri/desktop does not read these). Copy to .env.local and
# fill in the values from the Supabase project's API settings.
#
# These are baked into the static web bundle at build time and are therefore
# PUBLIC by design — the anon/publishable key is safe to expose because
# Row-Level Security is the real data gate (see docs/adr/0003).
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-publishable-key
