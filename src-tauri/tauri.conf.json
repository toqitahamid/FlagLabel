{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlagLabel",
  "version": "0.1.1",
  "identifier": "com.toqi.flaglabel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlagLabel",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Toqi Tahamid Sarker",
    "copyright": "© 2026 Toqi Tahamid Sarker",
    "category": "Productivity",
    "shortDescription": "Click flag wire–ground intersections in wildlife camera-trap photos.",
    "longDescription": "FlagLabel is a fast, keyboard-driven desktop labeler for distance-flag calibration in wildlife camera-trap surveys. Open a folder of reference photos, pick a transect, set a distance, and click the wire–ground intersection. Output is one small JSON file per image with image-pixel coordinates, ready for downstream camera-calibration code.",
    "homepage": "https://github.com/toqitahamid/FlagLabel",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/toqitahamid/FlagLabel/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxNUM5NTU1N0NGN0Q4N0QKUldSOTJQZDhWWlZjWVE5WGtDNDBMY0JsckFCemdyTTlIQWE4UG8vMTFMYXhRWlJ1aUhtYXRvSmcK"
    }
  }
}
